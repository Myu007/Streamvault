{
  "rewrites": [
    { "source": "/home", "destination": "/api/auth-check" }
  ],
  "headers": [
    {
      "source": "/home.html",
      "headers": [
        { "key": "Location", "value": "/" }
      ],
      "status": 302
    }
  ],
  "functions": {
    "api/auth-check.js": {
      "includeFiles": "home.html"
    }
  }
}
